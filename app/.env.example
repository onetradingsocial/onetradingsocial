NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_BUCKET=OneTradingSocial
# The app's own origin (used for OAuth redirect callbacks)
NEXT_PUBLIC_SITE_URL=
# The public marketing site origin (used to link the signup consent to /terms and /disclaimer)
NEXT_PUBLIC_MARKETING_URL=https://www.tradingsocial.io
# Stripe billing integration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TRADER_MONTHLY=price_...
STRIPE_PRICE_TRADER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
# Optional beta promo coupon applied to annual checkouts (76% off list = 80% off monthly rate).
# Remove/leave empty to end the promo.
STRIPE_COUPON_BETA_ANNUAL=

# MT5 auto-sync (phase 2)
# MetaApi.cloud API token (https://app.metaapi.cloud → API tokens). Feature ships dark without it.
METAAPI_TOKEN=
# Random secret; Vercel sends it as "Authorization: Bearer <value>" on cron invocations.
CRON_SECRET=
